# Copy to `.env` and fill with real values. Do not commit `.env`.
#
# What is AGENT_API_KEY?
# A locally generated shared secret that authenticates the MCP agent server
# against the FastAPI backend. It is NOT issued by Anthropic / OpenAI / GitHub
# / any third party. Generate one yourself:
#
#     openssl rand -hex 32
#
# The same value must be present in this .env (consumed by uvicorn) AND in the
# Windsurf MCP config (`env.AGENT_API_KEY` field) so the stdio server can
# attach the bearer header. See README "What is AGENT_API_KEY?" for details.
AGENT_API_KEY=change-me-to-a-long-random-string

# Scoped GitHub PAT (read/write for MR linking). Leave blank if MR attach-only.
GITHUB_PAT=

# Vite client target. Point at the locally running FastAPI instance.
VITE_API_URL=http://localhost:8000/api/v1

# SQLite file location. Defaults to ~/.taskable/taskable.db when unset, which
# is the recommended path because it survives `git clean`, is easy to back up,
# and is the same location the docker-compose stack bind-mounts. Override only
# if you have a specific reason (alternate filesystem, running multiple
# instances side-by-side, etc).
# DATABASE_URL=sqlite:////absolute/path/to/taskable.db

# PostgreSQL (production). Use your Neon/connection string.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Google OAuth credentials from Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret for signing session tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# Frontend URL used for OAuth redirect after login.
# In production, set to your Render/deployment URL.
FRONTEND_URL=http://localhost:5173
